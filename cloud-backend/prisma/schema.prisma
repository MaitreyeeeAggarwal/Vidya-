datasource db {
  provider = "postgresql" // Assuming Postgres for production cloud, but can be sqlite for dev
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-py" // Python Prisma Client for FastAPI
  interface = "asyncio"
}

model Teacher {
  id          String   @id @default(uuid())
  phoneNumber String   @unique // Format: +91XXXXXXXXXX
  fullName    String
  isActive    Boolean  @default(true)
  devices     Device[]
  createdAt   DateTime @default(now())
}

model Device {
  id           String   @id @default(uuid())
  deviceId     String   @unique // Hardware UUID generated by Android (e.g., ANDROID_ID or hardware serial)
  deviceModel  String?  // e.g., "Samsung Galaxy Tab A9"
  isSigned     Boolean  @default(true)
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @updatedAt
}

model OtpVerification {
  id          String   @id @default(uuid())
  phoneNumber String   @unique
  otpHash     String
  expiresAt   DateTime
}

enum SessionState {
  CREATED
  ACTIVE
  PAUSED
  ENDED
}

enum EventType {
  CONCEPT_STARTED
  QUESTION_ASKED
  STUDENT_NOMINATED
  ANSWER_RECORDED
  DOUBT_RAISED
}

model Session {
  id         String         @id // UUIDv7
  teacherId  String
  classId    String
  chapterId  String
  state      SessionState   @default(CREATED)
  startedAt  DateTime       @default(now())
  endedAt    DateTime?
  syncState  Boolean        @default(false)
  events     SessionEvent[]

  @@index([teacherId, classId])
}

model SessionEvent {
  id         String    @id // UUIDv7
  sessionId  String
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType  EventType
  timestamp  DateTime  @default(now())
  payload    String    @default("{}") 

  @@index([sessionId, timestamp])
}
